# Configuração de E-mail Global
# Copie este arquivo para .env e preencha com suas credenciais

# Servidor SMTP
SMTP_HOST=smtp.seudominio.com
SMTP_PORT=587

# Credenciais
SMTP_USER=usuario@seudominio.com
SMTP_PASSWORD=sua_senha_ou_app_password

# Endereço de origem
# Se não definido, usa SMTP_USER
SMTP_FROM=nao-responder@seudominio.com

# Segurança
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Driver de e-mail: 'smtp' (padrão) ou 'sendgrid'
EMAIL_DRIVER=smtp

# Configuração SendGrid (se usar EMAIL_DRIVER=sendgrid)
# Defina um remetente verificado: SMTP_FROM
SENDGRID_API_KEY=coloque_sua_chave_aqui
# Opcional: endpoint EU
# SENDGRID_ENDPOINT=https://api.eu.sendgrid.com

# Entregabilidade corporativa (opcional)
# Desabilita tracking de cliques/aberturas (alguns filtros corporativos bloqueiam tracking)
SENDGRID_DISABLE_TRACKING=false
# Desabilita tracking apenas para domínios específicos (separados por vírgula)
# Exemplo: EMAIL_DISABLE_TRACKING_DOMAINS=pactosolucoes.com.br,empresa.com
EMAIL_DISABLE_TRACKING_DOMAINS=

# Outras variáveis comuns
SECRET_KEY=troque-esta-chave
LANG=pt

# ========================================
# DATABASE
# ========================================
# PostgreSQL (Produção)
# Exemplo: postgresql://user:password@host:5432/database
DATABASE_URL=

# ========================================
# REDIS (Cache - Opcional)
# ========================================
# Se não configurado, usa SimpleCache (memória)
# Exemplo: redis://localhost:6379/0
REDIS_URL=

# ========================================
# AUTH0 (Autenticação OAuth)
# ========================================
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_DOMAIN=

# ========================================
# CLOUDFLARE R2 (Armazenamento de Arquivos)
# ========================================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_BUCKET_NAME=
CLOUDFLARE_PUBLIC_URL=

# ========================================
# APLICAÇÃO
# ========================================
# Email do administrador principal
ADMIN_EMAIL=admin@example.com

# Modo debug (NUNCA use True em produção!)
FLASK_DEBUG=False

# ========================================
# SENTRY (Monitoramento de Erros - Opcional)
# ========================================
# Se configurado, envia erros para o Sentry
SENTRY_DSN=

# ========================================
# CORS (Opcional)
# ========================================
# Lista de origens permitidas (separadas por vírgula)
# Exemplo: https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=