# ========================================
# VARIÁVEIS DE AMBIENTE - CSAPP
# ========================================
# IMPORTANTE: Copie este arquivo para .env e preencha com suas credenciais REAIS
# NUNCA commite o arquivo .env no Git!

# ========================================
# CONFIGURAÇÕES BÁSICAS
# ========================================
# Chave Secreta do Flask (CRÍTICO!)
# GERE UMA NOVA: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY="SUBSTITUA_POR_UMA_CHAVE_FORTE_GERADA_ALEATORIAMENTE_64_CARACTERES"

# Ponto de entrada da aplicação
FLASK_APP=run.py

# Ambiente (development, staging, production)
FLASK_ENV=development

# Debug mode (NUNCA use true em produção!)
FLASK_DEBUG=true

# Porta da aplicação
PORT=5000

# Idioma (pt ou en)
LANG=pt

# Versão da aplicação (para Sentry releases)
APP_VERSION=1.0.0

# ========================================
# MONITORAMENTO DE ERROS (SENTRY)
# ========================================
# Sentry DSN (obtenha em https://sentry.io/)
# Deixe vazio para desabilitar
SENTRY_DSN=

# ========================================
# BANCO DE DADOS
# ========================================
# PostgreSQL (Produção) - Obtenha do Railway ou seu provedor
# Formato: postgresql://usuario:senha@host:porta/database
DATABASE_URL=""

# URL Pública (compatibilidade)
DATABASE_PUBLIC_URL=""

# ========================================
# AUTH0 (Autenticação OAuth)
# ========================================
# Obtenha em: https://manage.auth0.com/
AUTH0_CLIENT_ID="seu_client_id_aqui"
AUTH0_CLIENT_SECRET="seu_client_secret_aqui"
AUTH0_DOMAIN="seu_dominio.auth0.com"

# Desativar Auth0 em desenvolvimento (usa login próprio)
DISABLE_AUTH0=true

# ========================================
# GOOGLE OAUTH (Integração com Google Calendar)
# ========================================
# Obtenha em: https://console.cloud.google.com/

# Desenvolvimento
GOOGLE_CLIENT_ID="seu_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu_google_client_secret"
GOOGLE_REDIRECT_URI=http://127.0.0.1:5000/agenda/callback

# Escopos do Google OAuth
GOOGLE_OAUTH_SCOPES="openid email profile https://www.googleapis.com/auth/calendar"

# Produção (Railway) - Descomente quando for fazer deploy
# GOOGLE_REDIRECT_URI=https://seu-app.up.railway.app/agenda/callback

# ========================================
# CLOUDFLARE R2 (Armazenamento de Arquivos)
# ========================================
# Obtenha em: https://dash.cloudflare.com/

# Endpoint da sua conta R2
CLOUDFLARE_ENDPOINT_URL="https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com"

# Credenciais de acesso
CLOUDFLARE_ACCESS_KEY_ID="sua_access_key_id"
CLOUDFLARE_SECRET_ACCESS_KEY="sua_secret_access_key"

# Nome do bucket e URL pública
CLOUDFLARE_BUCKET_NAME="seu-bucket-name"
CLOUDFLARE_PUBLIC_URL="https://pub-SEU_ID.r2.dev"

# ========================================
# USUÁRIO ADMINISTRADOR
# ========================================
# Email do administrador principal (terá acesso total)
ADMIN_EMAIL="admin@suaempresa.com"

# ========================================
# SMTP (Envio de E-mails)
# ========================================
# Servidor SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Credenciais
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_de_app

# Endereço de origem (se não definido, usa SMTP_USER)
SMTP_FROM=noreply@suaempresa.com

# Segurança
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# ========================================
# SENDGRID (Alternativa ao SMTP)
# ========================================
# Obtenha em: https://app.sendgrid.com/

# Driver de e-mail: 'smtp' (padrão) ou 'sendgrid'
EMAIL_DRIVER=smtp

# API Key do SendGrid (se usar EMAIL_DRIVER=sendgrid)
SENDGRID_API_KEY=SG.sua_api_key_aqui

# Desabilita tracking de cliques/aberturas
SENDGRID_DISABLE_TRACKING=true

# Desabilita tracking para domínios específicos (separados por vírgula)
EMAIL_DISABLE_TRACKING_DOMAINS=suaempresa.com.br

# ========================================
# REDIS (Cache - Opcional)
# ========================================
# Se não configurado, usa SimpleCache (memória)
# Exemplo: redis://localhost:6379/0
REDIS_URL=

# ========================================
# SENTRY (Monitoramento de Erros - Opcional)
# ========================================
# Se configurado, envia erros para o Sentry
# Obtenha em: https://sentry.io/
SENTRY_DSN=

# ========================================
# CORS (Opcional)
# ========================================
# Lista de origens permitidas (separadas por vírgula)
# Exemplo: https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=